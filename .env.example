# ─── Red Stellar ───────────────────────────────────────────────────────────────
VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
VITE_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_HORIZON_URL=https://horizon-testnet.stellar.org

# ─── Contratos desplegados (Testnet) ───────────────────────────────────────────
# Fuente de verdad: deployments.testnet.json
VITE_AUCTION_CONTRACT_ID=CAY7Z6TRRXDRGVYWBNSYVGXMRLW47XF2BGM4YBN2NWJNPU6R66UVOKRR
VITE_TOKEN_CONTRACT_ID=CBVDXELQKBRLVQRVZNZJFPPQS3CCJRHPQ6DSCUO3SSONBPUM3YI3BPQH
VITE_ASP_CONTRACT_ID=CBKCM7DFWKYLMQIXN3IE2IRFV7P2ZZQI3DPGZNQZRYB3R3FG7SJ3ZJNR
VITE_VERIFIER_CONTRACT_ID=CDPACMY5BFOL4OWEW42ESAICPVVXBNPE6QJVNFASQJTI2UT7JMTR3IB6

# ─── Admin on-chain ────────────────────────────────────────────────────────────
# Dirección que puede llamar set_capacity / pause / init en el contrato auction.
# Identidad 'idio' generada con stellar keys generate idio --network testnet
VITE_ON_CHAIN_ADMIN=GCTXTCGN5W3QG6GARAVOIQ6WV5QBFSAVHZ6J2SJENHFKQHMU36FJAK6R

# ─── Fuente de lectura on-chain ────────────────────────────────────────────────
# Dirección usada para leer subastas y balances cuando no hay wallet conectada.
# Por defecto el admin. Cambiar por cualquier cuenta con actividad.
VITE_READ_SOURCE=GCTXTCGN5W3QG6GARAVOIQ6WV5QBFSAVHZ6J2SJENHFKQHMU36FJAK6R

# ─── Covenant (ASP / allow-list ZK) ───────────────────────────────────────────
# Secrets CSV usados para generar el árbol Merkle de miembros (demo local).
# Formato: "secret0,secret1,secret2,..." — uno por banco autorizado.
# En producción esto viene del backend, nunca en el .env del cliente.
VITE_COVENANT_SECRETS=secret0,secret1,secret2,secret3,secret4,secret5,secret6,secret7

# ─── Backend API (opcional) ────────────────────────────────────────────────────
# URL de la API de autenticación real. Si no se define, la app usa el modo demo
# (localStorage, sin servidor). Ver backend/ para el servidor Express.
# Ejemplo local: http://localhost:3001
# Ejemplo producción: https://api.idio.example.com
VITE_API_URL=

# ─── Modo de datos inicial ─────────────────────────────────────────────────────
# 'demo'  → datos en localStorage, sin wallet requerida (default)
# 'chain' → lee de los contratos via Soroban RPC
VITE_DEFAULT_MODE=demo
